{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Precon deck list",
  "description": "Schema for decks.json — one entry per Magic precon tracked.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "set", "setType", "releaseDate", "colors", "msrp"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "description": "URL-safe slug. Lowercase letters, digits, hyphens only."
      },
      "name": { "type": "string", "minLength": 1 },
      "set": { "type": "string", "minLength": 1 },
      "setType": { "enum": ["standard", "ub", "commander"] },
      "releaseDate": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "ISO date (YYYY-MM-DD)."
      },
      "colors": {
        "type": "array",
        "items": { "enum": ["W", "U", "B", "R", "G", "C"] },
        "uniqueItems": true
      },
      "commander": { "type": "string" },
      "partner": { "type": "string" },
      "desc": { "type": "string" },
      "msrp": { "type": "number", "minimum": 0 },
      "currentPrice": { "type": ["number", "null"], "minimum": 0 },
      "priceSource": { "type": ["string", "null"] },
      "priceDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "singlesValue": { "type": "number", "minimum": 0 },
      "power": { "type": "number", "minimum": 0, "maximum": 10 },
      "powerScore": { "type": "number", "minimum": 0, "maximum": 10 },
      "powerBracket": { "enum": ["B1", "B2", "B3", "B4", "B5"] },
      "scryCheckSlug": { "type": "string" }
    }
  }
}
